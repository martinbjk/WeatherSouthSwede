# ─── KustVåg Environment Variables ───────────────────────────────────────────
#
# Copy this file to .env.local and fill in your values.
# Open-Meteo requires NO API key and is always used as primary data source.
# Stormglass is optional but adds: real water temperature + tide extreme times.

# Stormglass API key (optional)
# Free tier: 10 requests/day. Sign up at https://stormglass.io
# Without this key, the app still works fully using Open-Meteo + synthetic tides.
STORMGLASS_API_KEY=

# ─── Optional: Redis cache (Upstash) for production ──────────────────────────
# Without this, the app uses in-memory cache (resets on each serverless cold start).
# Get free Redis at https://upstash.com
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ─── Optional: Analytics ─────────────────────────────────────────────────────
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=kustvag.se
